local infylogic = (loadinfy loadinfytest) or not (loaddex or loadexec)

if infylogic then
    if loadinfy and not loadinfytest then
        pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/xb3rlinz/infiniteyield/master/source"))()
        end)
    elseif loadinfytest and not loadinfy then
        pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/xb3rlinz/infiniteyield/refs/heads/master/test"))()
        end)
    else
        print('[InfyLoad] Error: Conflicting options detected. `loadinfy` and `loadinfytest` cannot both be enabled simultaneously.')
    end
end
if loadexec then
    pcall(function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/xb3rlinz/infiniteyieldbackup/refs/heads/main/executor.lua"))()
    end)
end
if loaddex then
    pcall(function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/xb3rlinz/infiniteyieldbackup/main/dex.lua"))()
    end)
end

if notification then
    if infylogic and loaddex and loadexec then
        notify('All Loaded!')
    elseif infylogic and loaddex then
        notify('Infy & DarkDex Loaded!')
    elseif infylogic and loadexec then
        notify('Infy & Exec Loaded!')
    elseif loaddex and loadexec then
        notify('DarkDex & Exec Loaded!')
    elseif infylogic then
        notify('Infy Loaded!')
    elseif loaddex then
        notify('DarkDex Loaded!')
    elseif loadexec then
        notify('Exec Loaded!')
    end
end
